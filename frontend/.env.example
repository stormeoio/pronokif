# ============================================================
# PRONOKIF — FRONTEND ENVIRONMENT VARIABLES (template)
# ============================================================
# Copy this file to `frontend/.env` and fill in the real values.
# `frontend/.env` is gitignored — never commit it.
#
# Vite convention: variables MUST start with VITE_ to be exposed
# to the browser bundle. Migrated from CRA's REACT_APP_ prefix in
# Sprint 2 of the A2 refactor.
# ============================================================

# -- Backend API URL -----------------------------------------
# Dev:  http://localhost:8000
# Prod: https://api.pronokif.com
VITE_BACKEND_URL=http://localhost:8000

# -- Sentry frontend (S4, optional) --------------------------
# Public DSN — safe to expose in browser bundle.
VITE_SENTRY_DSN=
VITE_ENVIRONMENT=development

# -- Feature flags (optional) --------------------------------
# Examples for future use:
# VITE_FEATURE_MINIGAMES=true
# VITE_FEATURE_LEAGUE_CHAT=true

# -- DEV quick-login (optional, DEV builds only) -------------
# Tap the PronoKif logo on the login screen 5x to sign in with a
# test account. Only active when running the Vite dev server
# (import.meta.env.DEV) — stripped from production builds.
# Defaults to the seeded demo account (see backend/seed_demo.py).
# VITE_DEV_TEST_EMAIL=patou@demo.pronokif.com
# VITE_DEV_TEST_PASSWORD=demo1234
