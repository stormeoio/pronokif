# ============================================================
# PRONOKIF — FRONTEND ENVIRONMENT VARIABLES (template)
# ============================================================
# Copy this file to `frontend/.env` and fill in the real values.
# `frontend/.env` is gitignored — never commit it.
#
# CRA convention: variables MUST start with REACT_APP_ to be
# exposed to the browser bundle.
# When migrating to Vite (Sprint 2), prefix becomes VITE_.
# ============================================================

# -- Backend API URL -----------------------------------------
# Dev:  http://localhost:8000
# Prod: https://api.pronokif.com
REACT_APP_BACKEND_URL=http://localhost:8000

# -- Sentry frontend (S4, optional) --------------------------
# Public DSN — safe to expose in browser bundle.
REACT_APP_SENTRY_DSN=
REACT_APP_ENVIRONMENT=development

# -- Feature flags (optional) --------------------------------
# Examples for future use:
# REACT_APP_FEATURE_MINIGAMES=true
# REACT_APP_FEATURE_LEAGUE_CHAT=true
