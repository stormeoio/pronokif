# ============================================================
# PRONOKIF — BACKEND ENVIRONMENT VARIABLES (template)
# ============================================================
# Copy this file to `backend/.env` and fill in the real values.
# `backend/.env` is gitignored — never commit it.
# ============================================================

# -- MongoDB --------------------------------------------------
# Local dev: mongodb://localhost:27017
# Atlas:     mongodb+srv://<user>:<password>@cluster.xxxx.mongodb.net
MONGO_URL=mongodb://localhost:27017
DB_NAME=pronokif

# -- JWT (authentication) ------------------------------------
# Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# MUST be at least 32 bytes of entropy. Rotate on every deploy
# environment (dev / staging / prod must each have their own).
JWT_SECRET=CHANGE_ME_USE_secrets.token_urlsafe(48)

# -- CORS ----------------------------------------------------
# Comma-separated list of allowed origins. NEVER use "*" in prod.
# Dev:  http://localhost:3000
# Prod: https://pronokif.com,https://app.pronokif.com
CORS_ORIGINS=http://localhost:3000

# -- Public frontend URL --------------------------------------
# Used to generate links in emails (verification, reset, admin magic link).
FRONTEND_URL=https://pronokif.eu
ADMIN_FRONTEND_URL=https://pronokif.eu/admin

# Explicit browser origins allowed to call the API with cookies.
CORS_ORIGINS=https://pronokif.eu,http://localhost:3000,http://127.0.0.1:3000

# -- SMTP email delivery -------------------------------------
# Leave SMTP_HOST empty in local dev to log email links instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pronokif.eu
SMTP_FROM_NAME=PronoKif
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=15

# -- External APIs (optional, public endpoints) --------------
# Override only if you self-host a mirror or use a paid tier.
# OPENF1_API=https://api.openf1.org/v1
# JOLPICA_API=https://api.jolpi.ca/ergast/f1

# -- Rate limiting (S0-7) ------------------------------------
# Requests per minute per IP. Tune per environment.
RATE_LIMIT_PER_MINUTE=60

# -- Observability (S4) --------------------------------------
# Sentry DSN — leave empty to disable error tracking.
SENTRY_DSN=
ENVIRONMENT=development
LOG_LEVEL=INFO

# -- File storage (S4 — avatars uploads) ---------------------
# When STORAGE_BACKEND=local, files live under ./uploads/
# When =s3, set the S3_* vars and use Cloudflare R2 or AWS S3.
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
